PORT=5000

# MySQL: either a single URL OR discrete variables (see below).
# MYSQL_URL=mysql://USER:PASSWORD@127.0.0.1:3306/quickfix
MYSQL_DATABASE=quickfix
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# Set MYSQL_SSL=true for managed DBs that require TLS (e.g. some cloud hosts).
# MYSQL_SSL=true

JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=30d
CLIENT_URL=http://localhost:5173
FIREBASE_PROJECT_ID=fu-service

# Resend email delivery. The default sender works for initial Resend testing.
# Replace it with an address on your verified domain before production.
RESEND_API_KEY=
RESEND_FROM_EMAIL=FunService <onboarding@resend.dev>
RESEND_SUPPORT_TO=
# Optional: send review alerts somewhere else. Falls back to RESEND_SUPPORT_TO.
RESEND_REVIEW_TO=anything@moreumelaa.resend.app

# WhatsApp booking notifications. Use Cloud API for direct sending, or a custom webhook fallback.
WHATSAPP_AGENT_PHONE=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v20.0
WHATSAPP_AGENT_WEBHOOK_URL=

# Optional owner bootstrap. Set these before first backend start to create/update the owner login.
# The bootstrapped account receives role "owner" (full admin panel access).
ADMIN_NAME=FunService Admin
ADMIN_USER_ID=admin
ADMIN_EMAIL=admin@funservice.local
ADMIN_PHONE=9999999999
ADMIN_PASSWORD=
ADMIN_PASSWORD_RESET_ON_START=false
