{
  "name": "funservice-fullstack",
  "version": "1.0.0",
  "private": true,
  "description": "FunService full-stack home services marketplace with React and Express.",
  "scripts": {
    "install:all": "npm install --prefix frontend && npm install --prefix backend",
    "postinstall": "npm run install:all",
    "build": "npm run build --prefix frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "start": "npm start --prefix backend",
    "dev": "npm run dev --prefix backend"
  },
  "dependencies": {
    "@supabase/server": "^1.3.0",
    "@supabase/supabase-js": "^2.110.1",
    "resend": "^6.12.4"
  }
}
